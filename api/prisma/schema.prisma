// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

model Operador {
  id        String   @id @default(uuid())
  nome      String
  senha     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("operador")
}

model Visitor {
  id                 String    @id @default(uuid())
  publicKey          String    @map("public_key") @db.Text
  verified           Boolean   @default(false)
  challenge          String?
  challengeExpiresAt DateTime? @map("challenge_expires_at")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("visitor")
}

model Lead {
  id            String   @id @default(uuid())
  primeiro_nome String
  sobrenome     String
  contato       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([id])
  @@index([primeiro_nome])
  @@index([primeiro_nome, sobrenome])
  @@map("lead")
}

model Pedido {
  id            String @id @default(uuid())
  numero BigInt @default(autoincrement()) @unique  
  nome_completo String

  itens PedidoItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([numero])
  @@index([nome_completo])
  @@map("pedido")
}

model Produto {
  id        String  @id @default(uuid())
  nome      String @unique
  descricao String?
  preco     Decimal @db.Decimal(10, 2)
  imagemUrl String? @map("imagem_url")
  ativo     Boolean @default(true)

  adicionais AdicionalProduto[]
  adicionaisGlobais ProdutoAdicionalGlobal[]
  itens PedidoItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("produto")
}

model AdicionalGlobal {
  id    String  @id @default(uuid())
  nome  String
  preco Decimal @db.Decimal(10, 2)
  ativo Boolean @default(true)

  produtos ProdutoAdicionalGlobal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("adicional_global")
}

model ProdutoAdicionalGlobal {
  produto_id          String @map("produto_id")
  adicional_global_id String @map("adicional_global_id")

  produto          Produto          @relation(fields: [produto_id], references: [id], onDelete: Cascade)
  adicionalGlobal  AdicionalGlobal  @relation(fields: [adicional_global_id], references: [id], onDelete: Cascade)

  @@id([produto_id, adicional_global_id])
  @@map("produto_adicional_global")
}

model AdicionalProduto {
  id String @id @default(uuid())
  produto_id String @map("produto_id")
  nome String
  preco Decimal @db.Decimal(10,2)
  ativo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  produto Produto @relation(fields: [produto_id], references: [id], onDelete: Cascade)

  @@map("adicional_produto")
}

model PedidoItem {
  id String @id @default(uuid())

  pedido_id  String @map("pedido_id")
  produto_id String @map("produto_id")

  quantidade Int @default(1)

  preco_produto Decimal @db.Decimal(10, 2)

  adicional_venda Json?

  observacao String? @db.VarChar(140)

  pedido Pedido @relation(fields: [pedido_id], references: [id], onDelete: Cascade)

  produto Produto @relation(fields: [produto_id], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pedido_id])
  @@index([produto_id])
  @@map("pedido_item")
}

model ConfigImpressora {
  id        String   @id @default("default")
  ip        String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("config_impressora")
}